{
  "name": "@oltionzefi/burger",
  "version": "1.0.0",
  "main": "dist/main/index.js",
  "description": "Order a Burger and Burger will be ready for you to enjoy",
  "author": "Oltion Zefi <oltion.zefi@gmail.com>",
  "repository": "oltionzefi/burger",
  "license": "MIT",
  "private": true,
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "overrides": {
    "eslint": "^9.23.0"
  },
  "scripts": {
    "dev": "vite",
    "debug": "export ENABLE_ELECTRON_DEBUG=true && vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "pree2e": "vite build --mode=test",
    "e2e:cucumber": "vite build --config vite.web.config.ts && vite preview --config vite.web.config.ts --port 4173 & sleep 2 && npx cucumber-js --config cucumber.mjs; kill %1",
    "e2e:cucumber:dry": "cucumber-js --config cucumber.mjs --dry-run",
    "lint": "eslint \"src/**/*\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx,js,jsx}\"",
    "format": "prettier \"src/**/*.{tsx,ts,js,jsx,json,md}\"",
    "format:fix": "prettier \"src/**/*.{tsx,ts,js,jsx,json,md}\" --write",
    "format:check": "prettier --list-different \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@heroui/react": "^3.0.1",
    "electron-debug": "^4.1.0",
    "electron-log": "^5.3.3",
    "electron-updater": "^6.6.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.13.2",
    "react-router-dom": "^7.4.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/leaflet": "^1.9.17",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.1.1",
    "electron": "^35.1.3",
    "electron-builder": "^26.0.12",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.23.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.1"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
